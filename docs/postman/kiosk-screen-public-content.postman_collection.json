{
  "info": {
    "_postman_id": "7b5f8688-3487-47c3-a621-1f1cf39d13a4",
    "name": "Kiosk Screen - Public Content Upload API",
    "description": "Coleccion para crear API keys de administracion y simular subidas publicas de fotos y videos mediante multipart/form-data.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@example.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "apiKeyLabel",
      "value": "Postman public uploader",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "",
