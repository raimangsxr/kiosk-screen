  "item": [
    {
      "name": "0. Admin session and API key setup",
      "item": [
        {
          "name": "Login as admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('session cookie is received', function () {",
                  "  pm.expect(pm.cookies.get('kiosk_session')).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Autentica el admin. Postman conserva la cookie `kiosk_session` para los requests admin siguientes."
          },
          "response": []
        },
        {
          "name": "Create API key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API key is created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('apiKey', json.rawKey);",
                  "pm.collectionVariables.set('apiKeyId', json.record.id);",
                  "pm.test('raw API key saved to collection variable', function () {",
                  "  pm.expect(pm.collectionVariables.get('apiKey')).to.match(/^ksk_live_/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"{{apiKeyLabel}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/api-keys",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "api-keys"
              ]
            },
            "description": "Crea una API key. El script guarda `rawKey` en `apiKey` y `record.id` en `apiKeyId`."
          },
          "response": []
        },
        {
          "name": "List API keys",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API keys are listed', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/api-keys",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "api-keys"
              ]
            },
            "description": "Lista las keys del admin logado. No devuelve el valor raw de la key."
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. Public content uploads",
      "item": [
        {
          "name": "Upload photo",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestTitle', `${pm.collectionVariables.get('uploadTitle')} photo ${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('photo upload returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('contentId', json.id);",
                  "pm.collectionVariables.set('displayOrder', String(json.displayOrder));",
                  "pm.test('response is a photo content item', function () {",
                  "  pm.expect(json.contentType).to.eql('photo');",
                  "  pm.expect(json.mediaFile.mediaType).to.eql('image');",
                  "  pm.expect(json.displayOrder).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{apiKey}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{photoFilePath}}"
                },
                {
                  "key": "title",
                  "value": "{{requestTitle}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/public/content/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "content",
                "upload"
              ]
            },
            "description": "Sube una imagen publica. Antes de ejecutarlo, cambia `photoFilePath` por una ruta absoluta local."
          },
          "response": []
        },
        {
          "name": "Upload video",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestTitle', `${pm.collectionVariables.get('uploadTitle')} video ${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('video upload returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('contentId', json.id);",
                  "pm.collectionVariables.set('displayOrder', String(json.displayOrder));",
                  "pm.test('response is a video content item', function () {",
                  "  pm.expect(json.contentType).to.eql('video');",
                  "  pm.expect(json.mediaFile.mediaType).to.eql('video');",
                  "  pm.expect(json.displayOrder).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{apiKey}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{videoFilePath}}"
                },
                {
                  "key": "title",
                  "value": "{{requestTitle}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/public/content/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "content",
                "upload"
              ]
            },
            "description": "Sube un video publico. Antes de ejecutarlo, cambia `videoFilePath` por una ruta absoluta local."
          },
          "response": []
        },
        {
          "name": "Upload photo with manual title",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{apiKey}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{photoFilePath}}"
                },
                {
                  "key": "title",
                  "value": "Foto subida desde Postman",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/public/content/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "content",
                "upload"
              ]
            },
            "description": "Variante simple con titulo fijo para repetir manualmente."
          },
          "response": []
        }
      ]
    },
