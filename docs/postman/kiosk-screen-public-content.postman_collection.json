    {
      "name": "4. Key lifecycle checks",
      "item": [
        {
          "name": "Rotate API key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API key is rotated', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('apiKey', json.rawKey);",
                  "pm.collectionVariables.set('apiKeyId', json.record.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/api-keys/{{apiKeyId}}/rotate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "api-keys",
                "{{apiKeyId}}",
                "rotate"
              ]
            },
            "description": "Rota la key actual y reemplaza la variable `apiKey` por la nueva raw key."
          },
          "response": []
        },
