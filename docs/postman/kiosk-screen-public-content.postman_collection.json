              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "api-keys",
                "{{apiKeyId}}"
              ]
            },
            "description": "Revoca la key actual. Despues, las subidas publicas con `apiKey` deben devolver 403."
          },
          "response": []
        },
