    {
      "name": "3. Admin ads uploads",
      "item": [
        {
          "name": "Upload ad image",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ad image upload returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adId', json.id);",
                  "pm.test('response is an active ad', function () {",
                  "  pm.expect(json.isActive).to.eql(true);",
                  "  pm.expect(json.mediaFile.mediaType).to.eql('image');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{adImageFilePath}}"
                },
                {
                  "key": "advertiser",
                  "value": "Postman advertiser",
                  "type": "text"
                },
                {
                  "key": "isActive",
                  "value": "true",
                  "type": "text"
                },
                {
                  "key": "durationSeconds",
                  "value": "10",
                  "type": "text"
                },
                {
                  "key": "rotationAnimation",
